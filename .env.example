# ============================================
# THUX BIO + FORMS · variaveis de ambiente
# Copie para .env (local) e configure no Vercel (Project Settings > Environment Variables)
# ============================================

# Token da API do GHL (GoHighLevel / LeadConnector).
# Use um Private Integration Token (API v2). ESCOPOS OBRIGATORIOS:
#   - contacts.write      (criar/atualizar o contato)
#   - opportunities.write (criar a oportunidade na etapa "Lead" do pipeline Thux)
# Sem opportunities.write, o contato entra mas a oportunidade falha (401/403).
# SEM esse token, o /api/lead roda em "modo preview" (valida e loga, nao envia ao GHL).
GHL_API_TOKEN=

# Location (sub-conta) da Thux no GHL. Default ja aponta pro location do vault.
GHL_LOCATION_ID=KKNHDTekS1dDPnUnyeVF

# Os IDs dos custom fields (Empresa, Cargo, Faixa de Faturamento, MQL Score)
# ja estao fixos em lib/ghl.ts (constante CF) — nao precisam de env.
